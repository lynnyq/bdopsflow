# BDopsFlow .gitignore
# ------------------------------

# ==============================
# Go (Golang)
# ==============================
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.out
*.app

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
*.coverage
coverage.txt
coverage.html

# Dependency directories
vendor/

# Go workspace file
go.work

# Go environment
go.env

# ==============================
# Node.js / Vue3 / Frontend
# ==============================
node_modules/
dist/
dist-ssr/
*.local
.cache/
.vite/

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ==============================
# IDEs and Editors
# ==============================
# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Vim
*.swp
*.swo
*~

# ==============================
# OS Files
# ==============================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ==============================
# Project Specific
# ==============================
# Scheduler and Executor binaries
scheduler/bin/
scheduler/scheduler
executor/bin/
executor/executor
executor/main
scheduler/main

# Logs
*.log
logs/

# Environment variables files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Configuration files (keep *.yaml.example only)
scheduler/config*.yaml
scheduler/config*.yml
executor/config*.yaml
executor/config*.yml

# Database files
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Backup files
*.backup

# Docker
docker-compose.override.yml
