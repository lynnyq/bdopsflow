FROM golang:1.24-alpine AS builder

WORKDIR /app

COPY go.mod go.sum* ./
RUN go mod download

COPY . .

WORKDIR /app/executor
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o executor ./cmd/main.go

FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /root/

COPY --from=builder /app/executor/executor .

ENV EXECUTOR_ID=executor-1
ENV EXECUTOR_NAME=executor-1
ENV SCHEDULER_ADDR=localhost:50051
ENV SCHEDULER_ADDRS=""
ENV CAPACITY=10

CMD ["./executor"]
