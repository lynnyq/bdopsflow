FROM golang:1.24-alpine AS builder

WORKDIR /app

COPY go.mod go.sum* ./
RUN go mod download

COPY . .

WORKDIR /app/scheduler
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o scheduler ./cmd/main.go

FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /root/

COPY --from=builder /app/scheduler/scheduler .

ENV HTTP_PORT=8080
ENV GRPC_PORT=50051
ENV RQLITE_DSN=http://localhost:4001
ENV REDIS_ADDR=localhost:6379

EXPOSE 8080 50051

CMD ["./scheduler"]
